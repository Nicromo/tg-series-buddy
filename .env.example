# Получи у @BotFather: /newbot
BOT_TOKEN=

# Токен kinopoisk.dev (или совместимого poiskkino.dev). Получи у @kinopoiskdev_bot
KP_API_KEY=

# Базовый URL API. По умолчанию kinopoisk.dev:
KP_API_BASE=https://api.kinopoisk.dev/v1.4
# Если используешь ПоискКино (poiskkino.dev), раскомментируй строку ниже:
# KP_API_BASE=https://api.poiskkino.dev/v1.4

# Путь к файлу БД. На Railway укажи /data/bot.sqlite
DB_PATH=./data/bot.sqlite

# Опционально: Neon Postgres (DIRECT endpoint, БЕЗ -pooler)
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Опционально: Groq AI для умных подсказок и поиска по фото
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Опционально: дополнительные источники трейлеров (когда KP пуст)
# TMDB_API_KEY=     # https://www.themoviedb.org/settings/api (бесплатно)
# YOUTUBE_API_KEY=  # https://console.cloud.google.com → YouTube Data API v3 (10K/день бесплатно)

# Опционально: алерты о падениях бота
# SENTRY_DSN=
# OWNER_TG_ID=     # твой Telegram ID — получит stacktrace при unhandled exception
